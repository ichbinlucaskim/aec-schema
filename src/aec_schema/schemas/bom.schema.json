{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aec-schema/bom.schema.json",
  "title": "BOM",
  "description": "Bill of materials for one panel, suitable for automated procurement/cutting list generation.",
  "type": "object",
  "required": ["schema_version", "panel_id", "items"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "panel_id": { "type": "string" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["section", "count", "total_length_mm"],
        "additionalProperties": false,
        "properties": {
          "section": {
            "type": "string",
            "enum": ["2x3", "2x4", "2x6", "2x8", "2x10", "2x12"]
          },
          "count": { "type": "integer", "minimum": 1 },
          "total_length_mm": { "type": "number", "minimum": 1 }
        }
      }
    },
    "sheathing_area_m2": {
      "type": "number",
      "minimum": 0,
      "description": "Optional: exterior sheathing (OSB/plywood) area in m²"
    }
  }
}
