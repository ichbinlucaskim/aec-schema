{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aec-schema/framing.schema.json",
  "title": "Framing",
  "description": "Light wood framing members synthesised for a single panel. All dimensions in mm.",
  "type": "object",
  "required": ["schema_version", "panel_id", "members", "member_count"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "panel_id": { "type": "string" },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/member" }
    },
    "member_count": { "type": "integer", "minimum": 1 }
  },
  "$defs": {
    "member": {
      "type": "object",
      "required": ["id", "type", "role", "start", "end", "section", "length"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["stud", "plate", "header", "king", "jack", "sill", "cripple"],
          "description": "North American light wood framing member types"
        },
        "role": {
          "type": "string",
          "enum": [
            "bottom_plate", "top_plate", "standard_stud", "king_stud",
            "jack_stud", "header", "sill", "cripple_stud"
          ],
          "description": "Functional role within the framing assembly"
        },
        "start": { "$ref": "#/$defs/point3d" },
        "end": { "$ref": "#/$defs/point3d" },
        "section": {
          "type": "string",
          "enum": ["2x3", "2x4", "2x6", "2x8", "2x10", "2x12"],
          "description": "Nominal cross-section. e.g. '2x4' (actual 38x89mm), '2x6' (actual 38x140mm)"
        },
        "length": { "type": "number", "minimum": 1, "description": "Member length in mm" }
      }
    },
    "point3d": {
      "type": "object",
      "required": ["x", "y", "z"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number", "description": "mm along wall length" },
        "y": { "type": "number", "description": "mm through wall depth" },
        "z": { "type": "number", "description": "mm height above subfloor" }
      }
    }
  }
}
